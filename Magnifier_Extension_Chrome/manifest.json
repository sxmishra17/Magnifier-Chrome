{
  "manifest_version": 3,
  "name": "Magnifier",
  "version": "1.1.0",
  "description": "Magnify text, images & PDFs with a customisable lens. Zoom 1×–10×, three sizes, circle or rectangle, five cursor positions.",
  "author": "Magnifier Extension",

  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },

  "action": {
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    },
    "default_title": "Magnifier Settings",
    "default_popup": "popup/popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>", "file:///*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'"
  },

  "host_permissions": [
    "<all_urls>"
  ],

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "tabs"
  ]
}
